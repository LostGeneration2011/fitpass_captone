# Production Environment Variables
NODE_ENV=production

# Database
DATABASE_URL="your-production-database-url"

# JWT
JWT_SECRET="your-super-secure-jwt-secret-for-production"

# Email Service
MAILTRAP_HOST="live.smtp.mailtrap.io"
MAILTRAP_USER="your-production-mailtrap-user"
MAILTRAP_PASS="your-production-mailtrap-pass"
EMAIL_FROM="noreply@yourapp.com"

# PayPal Production
PAYPAL_CLIENT_ID="your-production-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-production-paypal-client-secret"
PAYPAL_BASE_URL="https://api.paypal.com"

# Google OAuth - Callback must point to Railway backend URL
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="https://your-backend-domain.up.railway.app/api/auth/google/callback"

# Frontend URLs
FRONTEND_URL="https://your-admin-domain.up.railway.app"
PRODUCTION_API_URL="https://your-backend-domain.up.railway.app/api"
PRODUCTION_WS_URL="wss://your-backend-domain.up.railway.app/ws"

# CORS Origins
ALLOWED_ORIGINS="https://your-admin-domain.vercel.app,https://your-expo-domain.com"

# App Store URLs (for email deep links)
IOS_APP_STORE_URL="https://apps.apple.com/app/fitpass/id123456789"
ANDROID_PLAY_STORE_URL="https://play.google.com/store/apps/details?id=com.fitpass.app"