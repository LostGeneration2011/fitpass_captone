@startuml FitPass_UI_Component_Wireframes
!theme plain
title FitPass - UI Components & Layouts

package "Mobile App Components" {
  rectangle "Login Form Component" as login_comp {
    ┌─────────────────────┐
    │    [FitPass Logo]   │
    ├─────────────────────┤
    │ Email: [__________] │
    │ Pass:  [__________] │
    ├─────────────────────┤
    │     [LOGIN BTN]     │
    ├─────────────────────┤
    │ [Student] [Teacher] │
    ├─────────────────────┤
    │   Forgot Password?  │
    │      Sign Up        │
    └─────────────────────┘
  }
  
  rectangle "Class Card Component" as class_card {
    ┌─────────────────────┐
    │   [Class Image]     │
    ├─────────────────────┤
    │ Yoga Basics         │
    │ Teacher: John Doe   │
    │ Mon/Wed/Fri 6PM     │
    ├─────────────────────┤
    │ $50/month           │
    │ 8/15 spots left     │
    ├─────────────────────┤
    │ [View] [Enroll]     │
    └─────────────────────┘
  }
  
  rectangle "QR Code Display" as qr_display {
    ┌─────────────────────┐
    │  Session Active     │
    ├─────────────────────┤
    │                     │
    │    [QR CODE]        │
    │    ████████         │
    │    ████████         │
    │                     │
    ├─────────────────────┤
    │ Students: 8/15      │
    │ [End Session]       │
    └─────────────────────┘
  }
  
  rectangle "Navigation Tabs" as nav_tabs {
    ┌─────────────────────┐
    │ [Home] [Classes]    │
    │ [Profile] [Scan QR] │
    └─────────────────────┘
  }
}

package "Admin Dashboard Components" {
  rectangle "Stats Card Component" as stats_card {
    ┌─────────────────────┐
    │      📊 150         │
    │   Total Users       │
    │   ↗️ +12 this week  │
    └─────────────────────┘
  }
  
  rectangle "Data Table Component" as data_table {
    ┌─────────────────────────────────────────┐
    │ [Search___] [Filter▼] [+Add] [Export]   │
    ├─────────────────────────────────────────┤
    │ ☐ | Name     | Email      | Role | ... │
    ├─────────────────────────────────────────┤
    │ ☐ | John S.  | john@..    | Std  | ... │
    │ ☐ | Jane D.  | jane@..    | Tchr | ... │
    ├─────────────────────────────────────────┤
    │         < 1 2 3 ... 10 >                │
    └─────────────────────────────────────────┘
  }
  
  rectangle "Sidebar Navigation" as sidebar_nav {
    ┌─────────────────────┐
    │ 🏠 Dashboard        │
    │ 👥 Users            │
    │ 📚 Classes          │
    │ 📅 Sessions         │
    │ 📝 Enrollments      │
    │ 📊 Reports          │
    │ ⚙️  Settings        │
    └─────────────────────┘
  }
  
  rectangle "Chart Component" as chart_comp {
    ┌─────────────────────┐
    │ Attendance Trend    │
    ├─────────────────────┤
    │ 100% ┤              │
    │  80% ┤ ▲─▲─▲        │
    │  60% ┤▲   ▲  ▲      │
    │  40% ┤               │
    │      └─────────────  │
    │      Jan Feb Mar    │
    └─────────────────────┘
  }
}

package "Common UI Elements" {
  rectangle "Button Styles" as buttons {
    [Primary Button]
    [Secondary Button] 
    [Danger Button]
    [Success Button]
    [ Icon Button ]
  }
  
  rectangle "Form Elements" as forms {
    Text Input: [_____________]
    Dropdown:   [Select v    ]
    Checkbox:   ☐ Option
    Radio:      ○ Choice 1 ● Choice 2
    TextArea:   [____________]
                [____________]
  }
  
  rectangle "Modal/Popup" as modal {
    ┌─────────────────────┐
    │ Modal Title    [ X ]│
    ├─────────────────────┤
    │                     │
    │    Modal Content    │
    │                     │
    ├─────────────────────┤
    │    [Cancel] [OK]    │
    └─────────────────────┘
  }
  
  rectangle "Loading States" as loading {
    [🔄 Loading...]
    [Progress Bar ████▓▓▓]
    [Skeleton Loading]
    [████▓▓▓▓▓▓▓▓▓▓]
  }
}

package "Responsive Layout" {
  rectangle "Mobile Layout" as mobile_layout {
    ┌─────────────┐
    │   Header    │
    ├─────────────┤
    │             │
    │   Content   │
    │             │
    ├─────────────┤
    │ Bottom Nav  │
    └─────────────┘
  }
  
  rectangle "Desktop Layout" as desktop_layout {
    ┌─────────────────────────────────┐
    │           Header                │
    ├─────┬───────────────────────────┤
    │     │                           │
    │Side │        Content            │
    │bar  │                           │
    │     │                           │
    └─────┴───────────────────────────┘
  }
  
  rectangle "Tablet Layout" as tablet_layout {
    ┌─────────────────────────────────┐
    │           Header                │
    ├─────────────────────────────────┤
    │                                 │
    │           Content               │
    │                                 │
    ├─────────────────────────────────┤
    │         Tab Navigation          │
    └─────────────────────────────────┘
  }
}

@enduml