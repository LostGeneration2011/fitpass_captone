{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API": "https://fitpass-backend.onrender.com/api",
        "EXPO_PUBLIC_WS": "wss://fitpass-backend.onrender.com/ws",
        "IS_PRODUCTION": "true"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API": "https://fitpass-backend.onrender.com/api",
        "EXPO_PUBLIC_WS": "wss://fitpass-backend.onrender.com/ws",
        "IS_PRODUCTION": "true"
      }
    },
    "production-ios": {
      "env": {
        "EXPO_PUBLIC_API": "https://fitpass-backend.onrender.com/api",
        "EXPO_PUBLIC_WS": "wss://fitpass-backend.onrender.com/ws",
        "IS_PRODUCTION": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}